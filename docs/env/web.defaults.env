# TradingAgents Web 平台默认环境（小米 MiMo / mimo）
# 用法: cp docs/env/web.defaults.env .env
# 文档: https://mimo.mi.com/docs/zh-CN/quick-start/summary/first-api-call

# --- LLM：小米 MiMo（mimo）默认 ---
# TradingAgents 通过 openai_compatible 接入 MiMo OpenAI 兼容 API
TRADINGAGENTS_LLM_PROVIDER=openai_compatible
TRADINGAGENTS_DEEP_THINK_LLM=mimo-v2.5-pro
TRADINGAGENTS_QUICK_THINK_LLM=mimo-v2.5-pro
TRADINGAGENTS_LLM_BACKEND_URL=https://api.xiaomimimo.com/v1
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese

# 小米 MiMo API Key（控制台 https://platform.xiaomimimo.com 或 mimo.mi.com）
# 按量付费格式 sk-xxxxx；Token Plan 格式 tp-xxxxx（需换 BASE_URL，见下方注释）
MIMO_API_KEY=

# webapi 启动时：若 MIMO_API_KEY 已设且 OPENAI_COMPATIBLE_API_KEY 未设，自动同步到后者
OPENAI_COMPATIBLE_API_KEY=

# --- Web 服务 ---
TRADINGAGENTS_DATA_DIR=/data
TRADINGAGENTS_WEB_HOST=0.0.0.0
TRADINGAGENTS_WEB_PORT=8080
TRADINGAGENTS_JOB_CONCURRENCY=1
TRADINGAGENTS_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- 测试开关 ---
# CI / 无 Key 本地演示: 设为 1（跳过 mimo，写 mock 报告）
TRADINGAGENTS_MOCK_GRAPH=0

# --- 可选：Token Plan 中国区（tp- 密钥时使用）---
# TRADINGAGENTS_LLM_BACKEND_URL=https://token-plan-cn.xiaomimimo.com/v1

# --- 可选：其他数据源 ---
# FRED_API_KEY=
# ALPHA_VANTAGE_API_KEY=
